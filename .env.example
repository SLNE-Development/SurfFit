# Postgres connection string used by @surffit/db (all apps + migrator)
DATABASE_URL=postgres://surffit:surffit@localhost:5432/surffit

# RabbitMQ connection string used by @surffit/core messaging
RABBITMQ_URL=amqp://surffit:surffit@localhost:5672

# Redis connection string (unused until a later phase)
REDIS_URL=redis://localhost:6379

# Auth.js secret — generate with `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET=changeme

# Base URL Auth.js uses to build callback URLs
AUTH_URL=http://localhost:3000

# Discord OAuth application client id (create at https://discord.com/developers/applications)
AUTH_DISCORD_ID=changeme

# Discord OAuth application client secret
AUTH_DISCORD_SECRET=changeme

# Comma-separated list of worker consumer group names to run; unset/empty = all groups
WORKER_QUEUES=

# Pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# Standard Node environment
NODE_ENV=development

# Port the current app binds to (web defaults 3000, worker health server defaults 3001)
PORT=3000

# S3-compatible object storage (MinIO in dev) used by @surffit/core storage provider
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=surffit
S3_SECRET_KEY=surffit123
S3_BUCKET=surffit
# MinIO needs path-style URLs; real S3 does not
S3_FORCE_PATH_STYLE=true

# MinIO is now used for avatars/exports; Mailpit remains unused until email arrives in a later phase
