{
  "name": "surffit",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "pnpm --filter @surffit/db generate",
    "db:migrate": "pnpm --filter @surffit/db migrate",
    "db:studio": "pnpm --filter @surffit/db studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3"
  }
}
